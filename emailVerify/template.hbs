<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Email Verification</title>

    <!-- Google Font (may fallback in some email clients) -->
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Source Code Pro', monospace;
            background-color: #f2f2f2;
        }

        .container {
            max-width: 620px;
            margin: 60px auto;
            background: #ffffff;
            padding: 50px 45px;
            border-radius: 12px;
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.08);
            border: 1px solid #eaeaea;
        }

        .header {
            text-align: center;
            padding-bottom: 25px;
            border-bottom: 1px solid #eeeeee;
        }

        .header h2 {
            margin: 0;
            font-size: 20px;
            letter-spacing: 2px;
            color: #000000;
        }

        .message {
            font-size: 14px;
            color: #000000;
            line-height: 1.8;
            padding: 35px 0;
        }

        .button-wrapper {
            text-align: center;
            margin: 40px 0;
        }

        .button {
            display: inline-block;
            padding: 15px 50px;
            background-color: #000000;
            color: #ffffff !important;
            text-decoration: none;
            font-weight: 600;
            letter-spacing: 2px;
            border-radius: 6px;
        }

        .fallback-link {
            font-size: 12px;
            color: #000000;
            background: #fafafa;
            padding: 14px;
            border-radius: 6px;
            border: 1px solid #eeeeee;
            word-break: break-all;
        }

        .footer {
            font-size: 11px;
            color: #888888;
            text-align: center;
            margin-top: 40px;
            border-top: 1px solid #eeeeee;
            padding-top: 20px;
        }
    </style>
</head>

<body>
    <div class="container">

        <div class="header">
            <h2>EMAIL_VERIFICATION</h2>
        </div>

        <div class="message">
            <p>> Hello,</p>

            <p>
                Thank you for registering. To activate your account,
                please verify your email address using the secure link below.
            </p>

            <div class="button-wrapper">
                <a href="http://localhost:5173/verify/{{token}}" target="_blank" class="button">
                    VERIFY_ACCOUNT
                </a>
            </div>

            <p>If the button does not work, copy and paste this link into your browser:</p>

            <div class="fallback-link">
                http://localhost:5173/verify/{{token}}
            </div>

            <p style="margin-top:30px;">
                If you did not initiate this request, you may safely ignore this email.
            </p>
        </div>

        <div class="footer">
            &copy; 2025 Webelite Builders. Secure Authentication System.
        </div>

    </div>
</body>

</html>
